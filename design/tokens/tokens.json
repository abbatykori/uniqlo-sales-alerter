{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "color": {
    "surface": {
      "canvas":  { "$type": "color", "$value": "#E8EDF2" },
      "raised":  { "$type": "color", "$value": "#FFFFFF" },
      "sunken":  { "$type": "color", "$value": "#DEE3E9" }
    },
    "text": {
      "primary":   { "$type": "color", "$value": "#2C3947" },
      "secondary": { "$type": "color", "$value": "#547A95" },
      "muted":     { "$type": "color", "$value": "#8B9AAB" },
      "inverse":   { "$type": "color", "$value": "#FFFFFF" }
    },
    "border": {
      "default": { "$type": "color", "$value": "#CBD5DF" },
      "strong":  { "$type": "color", "$value": "#547A95" }
    },
    "accent": {
      "primary":       { "$type": "color", "$value": "#C2A56D" },
      "primary-muted": { "$type": "color", "$value": "#E8DDC4" }
    },
    "status": {
      "success": { "$type": "color", "$value": "#3F8862" },
      "warning": { "$type": "color", "$value": "#C2A56D" },
      "error":   { "$type": "color", "$value": "#A14040" },
      "info":    { "$type": "color", "$value": "#547A95" }
    }
  },
  "radius": {
    "xs":   { "$type": "dimension", "$value": "4px" },
    "sm":   { "$type": "dimension", "$value": "8px" },
    "md":   { "$type": "dimension", "$value": "12px" },
    "lg":   { "$type": "dimension", "$value": "16px" },
    "full": { "$type": "dimension", "$value": "9999px" }
  },
  "shadow": {
    "sm": { "$type": "shadow", "$value": "0 1px 2px rgba(44, 57, 71, 0.06)" },
    "md": { "$type": "shadow", "$value": "0 4px 12px rgba(44, 57, 71, 0.08)" },
    "lg": { "$type": "shadow", "$value": "0 12px 32px rgba(44, 57, 71, 0.12)" }
  }
}
