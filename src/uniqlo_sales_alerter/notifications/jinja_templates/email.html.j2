<!doctype html>
<html>
<body style="margin:0;padding:0;background:#f7f7f7;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif;color:#222;">
  <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#f7f7f7;">
    <tr>
      <td align="center" style="padding:24px 12px;">
        <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="600" style="max-width:600px;background:#fff;border:1px solid #e5e5e5;border-radius:6px;overflow:hidden;">

          <tr>
            <td style="padding:18px 22px;background:#A00000;color:#fff;font-size:18px;font-weight:600;">
              Uniqlo Sale Alert
              <span style="float:right;font-weight:400;">{{ deals|length }} deal{% if deals|length != 1 %}s{% endif %}</span>
            </td>
          </tr>

          {% for v in deals %}
            {% set deal = v.deal %}
            {% set price = v.price %}
          <tr>
            <td style="padding:16px 22px;border-top:1px solid #f0f0f0;">
              <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
                <tr>
                  <td valign="top" width="140" style="padding-right:14px;">
                    {% if deal.image_url %}
                      <img src="{{ deal.image_url }}" alt="" width="140" height="180" style="display:block;width:140px;height:180px;object-fit:cover;border-radius:4px;border:1px solid #eee;" />
                    {% else %}
                      <div style="width:140px;height:180px;background:#f4f4f4;border-radius:4px;color:#999;text-align:center;line-height:180px;font-size:13px;">No image</div>
                    {% endif %}
                  </td>
                  <td valign="top" style="vertical-align:top;">
                    <div style="font-size:16px;font-weight:600;color:#222;line-height:1.3;">
                      {{ deal.name }}
                      {% if deal.is_watched %}
                        <span style="display:inline-block;margin-left:6px;padding:1px 6px;background:#C2A56D;color:#fff;font-size:11px;border-radius:3px;">Watched</span>
                      {% endif %}
                    </div>

                    {% if v.colors %}
                      <div style="margin-top:4px;font-size:12px;color:#666;text-transform:uppercase;letter-spacing:0.04em;">
                        {{ v.colors | join(' · ') }}
                      </div>
                    {% endif %}

                    {% if v.rating %}
                      <div style="margin-top:4px;font-size:12px;color:#888;">{{ v.rating }}</div>
                    {% endif %}

                    <div style="margin-top:8px;font-size:14px;">
                      {% if price.show_strikethrough %}
                        <span style="color:#aaa;text-decoration:line-through;">{{ price.original_text }}</span>
                        <span style="margin-left:6px;color:#A00000;font-weight:600;">{{ price.sale_text }}</span>
                        <span style="margin-left:6px;color:#3F8862;font-weight:600;">{{ price.discount_label }}</span>
                      {% elif price.show_sale_badge %}
                        <span style="color:#A00000;font-weight:600;">{{ price.sale_text }}</span>
                        <span style="margin-left:6px;padding:1px 6px;background:#3F8862;color:#fff;font-size:11px;border-radius:3px;">Sale</span>
                      {% else %}
                        <span style="color:#222;font-weight:600;">{{ price.sale_text }}</span>
                      {% endif %}
                    </div>

                    {% if v.matched_filter_names %}
                      <div style="margin-top:8px;">
                        {% for name in v.matched_filter_names %}
                          <span style="display:inline-block;margin:1px 4px 1px 0;padding:2px 8px;background:#E8DDC4;color:#5a4520;font-size:11px;border-radius:9999px;">{{ name }}</span>
                        {% endfor %}
                      </div>
                    {% elif deal.is_watched %}
                      <div style="margin-top:8px;">
                        <span style="display:inline-block;padding:2px 8px;background:#3F8862;color:#fff;font-size:11px;border-radius:9999px;">Watched variant</span>
                      </div>
                    {% endif %}

                    <div style="margin-top:10px;font-size:13px;">
                      {% for cell in v.size_cells %}
                        <a href="{{ cell.url }}" style="display:inline-block;margin:2px 8px 2px 0;color:#1a73e8;text-decoration:none;">
                          <strong>{{ cell.label }}</strong>{% if cell.stock_text %}
                            {% if cell.is_low_stock %}
                              <span style="margin-left:4px;padding:1px 6px;background:#A14040;color:#fff;border-radius:3px;font-size:11px;">{{ cell.stock_text }}</span>
                            {% else %}
                              <span style="margin-left:4px;color:#999;font-size:11px;">({{ cell.stock_text }})</span>
                            {% endif %}
                          {% endif %}
                        </a>
                      {% endfor %}
                    </div>

                    {% if server_url and v.ignore_url %}
                      <div style="margin-top:10px;font-size:12px;color:#888;">
                        <a href="{{ v.ignore_url }}" style="color:#888;text-decoration:none;margin-right:10px;">Ignore</a>
                        {% if deal.is_watched %}
                          {% for cell in v.size_cells %}{% if v.unwatch_url_by_size.get(cell.label) %}
                            <a href="{{ v.unwatch_url_by_size[cell.label] }}" style="color:#A00000;text-decoration:none;margin-right:10px;">Unwatch {{ cell.label }}</a>
                          {% endif %}{% endfor %}
                        {% else %}
                          {% for cell in v.size_cells %}{% if v.watch_url_by_size.get(cell.label) %}
                            <a href="{{ v.watch_url_by_size[cell.label] }}" style="color:#A00000;text-decoration:none;margin-right:10px;">Watch {{ cell.label }}</a>
                          {% endif %}{% endfor %}
                        {% endif %}
                      </div>
                      {% if v.snooze_urls_by_filter %}
                        {% for fid, snooze_urls in v.snooze_urls_by_filter.items() %}
                          <div style="margin-top:6px;font-size:11px;color:#888;">
                            Snooze {{ names_by_id.get(fid, '#' ~ fid) }}:
                            {% for label, url in snooze_urls %}
                              <a href="{{ url }}" style="color:#5a4520;text-decoration:none;margin-right:8px;">{{ label }}</a>
                            {% endfor %}
                          </div>
                        {% endfor %}
                      {% endif %}
                    {% endif %}
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          {% endfor %}

          <tr>
            <td style="padding:12px 22px;background:#fafafa;font-size:11px;color:#888;text-align:center;border-top:1px solid #eee;">
              {% if server_url %}
                <a href="{{ server_url }}/settings" style="color:#888;text-decoration:none;">Settings</a>
              {% else %}
                Set server_url in settings to enable action buttons.
              {% endif %}
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
